# ============================================================
# Finance Manager - 环境变量样例
# 复制为 .env 后填入真实值
# ============================================================

# ---- Postgres (本地用 docker compose 起) ----
POSTGRES_USER=finance
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=finance
DATABASE_URL=postgresql+psycopg://finance:change_me_in_prod@db:5432/finance

# ---- Backend ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000
SECRET_KEY=please_replace_with_openssl_rand_hex_32

# 注意:本项目后端不直接调用 LLM。所有 AI 推理在上层 Agent(OpenClaw / Hermes Agent)那一侧
# 通过 MCP 协议调用本项目的 mcp_server。因此**不需要** Anthropic / OpenAI 等 API key。

# ---- Frontend ----
NEXT_PUBLIC_API_BASE=http://localhost:8000/api

# ---- MCP Server ----
MCP_BACKEND_URL=http://backend:8000
MCP_API_TOKEN=replace_with_a_random_token

# ---- 可选:对象存储(账单 PDF/截图) ----
# S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
# S3_BUCKET=finance-uploads
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ---- 可选:股票行情数据源 ----
# QUOTE_PROVIDER=sina   # sina / tencent / yahoo
